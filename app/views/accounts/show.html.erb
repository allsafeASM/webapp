<div class="max-w-2xl mx-auto bg-surface rounded-xl shadow-lg p-6 mt-8">
  <h1 class="text-2xl font-bold mb-6 text-gray-100">Your Account</h1>
  <div class="mb-8">
    <p class="mb-2"><span class="font-semibold text-gray-300">Email:</span> <span class="text-main"><%= @user.email_address %></span></p>
    <% if @user.verified_at? %>
      <span class="inline-block px-3 py-1 rounded-full bg-green-900 text-green-200 text-xs font-semibold">Verified</span>
    <% else %>
      <span class="inline-block px-3 py-1 rounded-full bg-yellow-900 text-yellow-200 text-xs font-semibold">Unverified</span>
    <% end %>
  </div>

  <h2 class="text-lg font-semibold mb-4 text-gray-200">Linked Social Accounts</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-4">
    <% @identities.each do |identity| %>
      <div class="flex items-center justify-between gap-4 bg-background rounded-lg p-4 shadow">
        <div class="flex items-center gap-4">
          <div class="flex flex-col items-center gap-1">
            <% if identity.image.present? %>
              <img src="<%= identity.image %>" alt="<%= identity.name %> avatar" class="w-12 h-12 rounded-full border-2 border-primary hover:border-primary-hover" />
            <% else %>
              <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl font-bold text-blue-200">
                <%= identity.name[0].upcase %>
              </div>
            <% end %>
            <%= button_to 'Unlink', identity_path(identity), method: :delete, class: 'text-danger text-xs font-semibold shadow hover:text-danger-hover transition cursor-pointer', form: { data: { turbo_confirm: 'Are you sure you want to unlink this account?' } } %>
          </div>
          <div>
            <div class="font-semibold text-main"><%= identity.name.presence || identity.provider.capitalize %></div>
            <div class="text-muted text-sm"><%= identity.email %></div>
            <div class="mt-1 text-xs text-primary font-semibold flex items-center gap-1">
              <svg class="w-4 h-4 inline" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 00-1.414 0L9 11.586 6.707 9.293a1 1 0 00-1.414 1.414l3 3a1 1 0 001.414 0l7-7a1 1 0 000-1.414z" clip-rule="evenodd"/></svg>
              <span><%= identity.provider == 'google_oauth2' ? 'Google' : 'GitHub' %> account linked</span>
            </div>
          </div>
        </div>
      </div>
    <% end %>
    <% if @identities.empty? %>
      <div class="col-span-2 text-muted italic">No social accounts linked.</div>
    <% end %>
  </div>
  <div class="flex flex-col gap-4 mb-8">
    <% unless @identities.any? { |i| i.provider == 'google_oauth2' } %>
      <%= button_to '/auth/google_oauth2', method: :post, data: { turbo: false }, class: 'cursor-pointer w-full flex items-center justify-center gap-2 px-6 py-2 rounded-lg bg-blue-600 text-white font-semibold shadow hover:bg-blue-700 transition' do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M21.805 10.023h-9.765v3.977h5.617c-.242 1.242-1.484 3.648-5.617 3.648-3.383 0-6.148-2.805-6.148-6.25s2.765-6.25 6.148-6.25c1.93 0 3.227.82 3.969 1.523l2.711-2.648c-1.711-1.594-3.922-2.57-6.68-2.57-5.523 0-10 4.477-10 10s4.477 10 10 10c5.742 0 9.547-4.023 9.547-9.711 0-.652-.07-1.148-.156-1.539z"/></svg>
        <span>Link Google Account</span>
      <% end %>
    <% end %>
    <% unless @identities.any? { |i| i.provider == 'github' } %>
      <%= button_to '/auth/github', method: :post, data: { turbo: false }, class: 'cursor-pointer w-full flex items-center justify-center gap-2 px-6 py-2 rounded-lg bg-blue-600 text-white font-semibold shadow hover:bg-blue-700 transition' do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.627 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.419-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.824 1.102.824 2.222v3.293c0 .319.192.694.801.576 4.769-1.589 8.201-6.086 8.201-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span>Link GitHub Account</span>
      <% end %>
    <% end %>
  </div>
  <div>
    <%= link_to 'Reset Password', new_password_path, class: 'px-4 py-1.5 rounded-lg bg-danger text-main font-semibold shadow hover:bg-danger-hover transition cursor-pointer' %>
  </div>
</div>