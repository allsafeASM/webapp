<div class="max-w-md mx-auto bg-surface rounded-xl shadow-lg p-6 mt-8">
  <h1 class="text-2xl font-bold mb-6 text-main">Reset Your Password</h1>

  <%= form_with url: passwords_path, method: :post, local: true, html: { class: 'space-y-6' } do |form| %>
    <div>
      <%= form.label :email_address, 'Email Address', class: 'block text-sm font-medium text-muted mb-1' %>
      <%= form.email_field :email_address, required: true, autofocus: true, class: 'w-full rounded-lg border border-border bg-background text-text-main px-4 py-2 focus:ring-2 focus:ring-primary focus:border-primary transition' %>
    </div>
    <div>
      <%= form.submit 'Send Reset Instructions', class: 'cursor-pointer w-full px-6 py-2 rounded-lg bg-primary text-main font-semibold shadow hover:bg-primary-hover transition' %>
    </div>
  <% end %>
</div>
