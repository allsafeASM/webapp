<div class="bg-success-surface/10 border border-success-text/20 rounded-lg p-4 mt-4">
  <div class="flex items-start space-x-3">
    <div class="flex-shrink-0">
      <svg class="w-6 h-6 text-low" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
      </svg>
    </div>
    <div class="flex-1">
      <h4 class="text-sm font-semibold text-low mb-3">🤖 AI Analysis Results</h4>
      <div class="text-sm text-main">
        <% if result.is_a?(Array) %>
          <ul class="space-y-2">
            <% result.each do |item| %>
              <li class="flex items-start space-x-2">
                <span class="text-low font-bold mt-1">•</span>
                <span class="flex-1"><%= item %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="prose prose-sm max-w-none">
            <%= simple_format(result) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>