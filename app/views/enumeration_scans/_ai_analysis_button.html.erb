<% if scan.status&.downcase == 'completed' %>
  <%= form_with(url: domain_enumeration_scan_ai_analysis_path(@domain, scan), method: :post,
                data: { turbo_stream: true }, 
                class: "inline-block") do |form| %>
    <%= form.button type: "submit", 
                   class: "cursor-pointer inline-flex items-center px-4 py-2 bg-gradient-to-r from-purple-600 to-blue-600 text-white text-sm font-semibold rounded-lg hover:from-purple-700 hover:to-blue-700 transition-all duration-200 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
      </svg>
      🤖 AI Analysis
    <% end %>
  <% end %>
<% end %>
