<div class="bg-surface rounded-xl shadow-lg p-6 mt-8">
  <div class="flex justify-between items-start mb-4">
    <div>
      <h1 class="text-lg font-semibold text-main">Enumeration Scan Details</h1>
      <p class="text-sm text-muted">Overview of the enumeration scan status and findings.</p>
    </div>
    <%
      status_class = if scan.status&.downcase == 'completed'
                       'bg-success-surface text-success-text'
                     elsif ['running', 'pending'].include?(scan.status&.downcase)
                       'bg-warning-surface text-warning-text'
                     elsif scan.status&.downcase == 'failed'
                       'bg-danger-surface text-danger-text'
                     else
                       'bg-background text-main'
                     end
    %>
    <div class="flex items-center space-x-2">
      <%= render 'shared/scan_status_icon', status: scan.status %>
      <span class="text-sm font-semibold px-3 py-1 rounded-full whitespace-nowrap <%= status_class %>">
        <%= scan.status&.capitalize %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm border-t border-border pt-4">
    <p class="text-muted"><span class="font-semibold text-main">Requested:</span> <%= scan.created_at.to_formatted_s(:long) %></p>
    <p class="text-muted"><span class="font-semibold text-main">Assets Found:</span> <%= scan.total_assets || 0 %></p>
    <% if scan.status&.downcase == 'completed' %>
      <p class="text-muted"><span class="font-semibold text-main">Completed at:</span> <%= scan.completed_at&.to_formatted_s(:long) %></p>
    <% end %>
    <% if scan.status&.downcase == 'failed' && scan.failure_reason.present? %>
      <p class="text-danger-text col-span-full"><span class="font-semibold">Reason:</span> <%= scan.failure_reason %></p>
    <% end %>
  </div>

  <div class="mt-6 text-right">
    <%= link_to 'Back to Asset', domain_path(@domain), data: { turbo_frame: "_top" }, class: 'text-main font-semibold hover:underline text-sm' %>
  </div>
</div>

<div class="bg-surface rounded-xl shadow-lg p-6 mt-8">
  <h3 class="text-lg font-semibold text-main mb-2">Results</h3>
  <% if results.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-3 px-2 font-semibold text-main">Name</th>
            <th class="text-left py-3 px-2 font-semibold text-main hidden sm:table-cell">IP</th>
            <th class="text-left py-3 px-2 font-semibold text-main hidden md:table-cell">Port</th>
            <th class="text-left py-3 px-2 font-semibold text-main hidden lg:table-cell">Status</th>
            <th class="text-left py-3 px-2 font-semibold text-main">URL</th>
            <th class="text-left py-3 px-2 font-semibold text-main hidden lg:table-cell">Title</th>
            <th class="text-left py-3 px-2 font-semibold text-main hidden lg:table-cell">Webserver</th>
          </tr>
        </thead>
        <tbody>
          <% results.each do |result| %>
            <tr class="border-b border-border/50 hover:bg-background/50 transition-colors">
              <td class="py-3 px-2">
                <div class="text-main font-medium"><%= result.name %></div>
                <div class="text-muted text-xs mt-1 md:hidden">
                  IP: <%= result.ip %> | Port: <%= result.port %>
                </div>
              </td>
              <td class="py-3 px-2 text-main hidden md:table-cell">
                <%= result.ip %>
              </td>
              <td class="py-3 px-2 text-main hidden md:table-cell">
                <%= result.port %>
              </td>
              <td class="py-3 px-2 hidden lg:table-cell">
                <% if result.status_code %>
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium
                    <%= result.status_code.to_s.start_with?('2') ? 'bg-success-surface text-success-text' : 
                        result.status_code.to_s.start_with?('3') ? 'bg-warning-surface text-warning-text' :
                        'bg-danger-surface text-danger-text' %>">
                    <%= result.status_code %>
                  </span>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </td>
              <td class="py-3 px-2">
                <% if result.url.present? %>
                  <a href="<%= result.url %>" target="_blank" class="text-primary hover:underline break-all">
                    <%= truncate(result.url, length: 40) %>
                  </a>
                  <div class="text-muted text-xs mt-1 lg:hidden">
                    <% if result.status_code %>
                      Status: <%= result.status_code %>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-muted">-</span>
                <% end %>
              </td>
              <td class="py-3 px-2 text-main hidden lg:table-cell">
                <%= truncate(result.title, length: 30) if result.title.present? %>
              </td>
              <td class="py-3 px-2 text-main hidden lg:table-cell">
                <%= result.webserver if result.webserver.present? %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <!-- Mobile-only details cards for hidden columns -->
    <div class="lg:hidden mt-4 space-y-2">
      <% results.each_with_index do |result, index| %>
        <details class="bg-background rounded-lg overflow-hidden">
          <summary class="px-4 py-2 cursor-pointer hover:bg-surface transition-colors text-sm font-medium text-main">
            View details for <%= result.name %>
          </summary>
          <div class="px-4 py-3 border-t border-border/50 space-y-2 text-sm">
            <% if result.title.present? %>
              <div><span class="font-semibold text-muted">Title:</span> <span class="text-main"><%= result.title %></span></div>
            <% end %>
            <% if result.webserver.present? %>
              <div><span class="font-semibold text-muted">Webserver:</span> <span class="text-main"><%= result.webserver %></span></div>
            <% end %>
          </div>
        </details>
      <% end %>
    </div>
  <% else %>
    <div class="text-muted text-sm">No results yet. The scan might be in progress or no assets were found.</div>
  <% end %>
</div>
