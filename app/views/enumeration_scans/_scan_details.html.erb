<div class="bg-surface rounded-xl shadow-lg p-6 mt-8">
  <div class="flex justify-between items-start mb-4">
    <div>
      <h1 class="text-lg font-semibold text-main">Enumeration Scan Details</h1>
      <p class="text-sm text-muted">Overview of the enumeration scan status and findings.</p>
    </div>
    <%
      status_class = if scan.status&.downcase == 'completed'
                       'bg-success-surface text-success-text'
                     elsif ['running', 'pending'].include?(scan.status&.downcase)
                       'bg-warning-surface text-warning-text'
                     elsif scan.status&.downcase == 'failed'
                       'bg-danger-surface text-danger-text'
                     else
                       'bg-background text-main'
                     end
    %>
    <div class="flex items-center space-x-2">
      <%= render 'shared/scan_status_icon', status: scan.status %>
      <span class="text-sm font-semibold px-3 py-1 rounded-full whitespace-nowrap <%= status_class %>">
        <%= scan.status&.capitalize %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm border-t border-border pt-4">
    <p class="text-muted"><span class="font-semibold text-main">Requested:</span> <%= scan.created_at.to_formatted_s(:long) %></p>
    <p class="text-muted"><span class="font-semibold text-main">Assets Found:</span> <%= scan.total_assets || 0 %></p>
    <% if scan.status&.downcase == 'completed' %>
      <p class="text-muted"><span class="font-semibold text-main">Completed at:</span> <%= scan.completed_at&.to_formatted_s(:long) %></p>
    <% end %>
    <% if scan.status&.downcase == 'failed' && scan.failure_reason.present? %>
      <p class="text-danger-text col-span-full"><span class="font-semibold">Reason:</span> <%= scan.failure_reason %></p>
    <% end %>
  </div>

  <div class="mt-6 text-right">
    <%= link_to 'Back to Asset', domain_path(@domain), data: { turbo_frame: "_top" }, class: 'text-main font-semibold hover:underline text-sm' %>
  </div>
</div>

<div class="bg-surface rounded-xl shadow-lg p-6 mt-8">
  <h3 class="text-lg font-semibold text-main mb-2">Results</h3>
  <% if results.any? %>
    <ul class="space-y-4">
      <% results.each do |result| %>
        <li class="bg-background p-4 rounded-lg shadow-sm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4 gap-y-2 text-sm">
            <div>
              <span class="font-semibold text-muted">Name:</span> <span class="text-main"><%= result.name %></span>
            </div>
            <div>
              <span class="font-semibold text-muted">URL:</span> <span class="text-main break-all"><%= result.url %></span>
            </div>
            <div>
              <span class="font-semibold text-muted">IP:</span> <span class="text-main"><%= result.ip %></span>
            </div>
            <div>
              <span class="font-semibold text-muted">Port:</span> <span class="text-main"><%= result.port %></span>
            </div>
            <div>
              <span class="font-semibold text-muted">Status Code:</span> <span class="text-main"><%= result.status_code %></span>
            </div>
            <div>
              <span class="font-semibold text-muted">Title:</span> <span class="text-main"><%= result.title %></span>
            </div>
            <div class="col-span-full">
              <span class="font-semibold text-muted">Webserver:</span> <span class="text-main"><%= result.webserver %></span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="text-muted text-sm">No results yet. The scan might be in progress or no assets were found.</div>
  <% end %>
</div>
