<div class="max-w-md mx-auto bg-surface rounded-xl shadow-lg p-6 mt-8">
  <h1 class="text-2xl font-bold mb-6 text-main">Create Your Account</h1>
  <div class="mb-6">
    <div class="flex flex-col gap-4">
      <%= button_to auth_path(provider: 'google_oauth2'), method: :post, class: 'cursor-pointer w-full flex items-center justify-center gap-2 px-6 py-2 rounded-lg bg-surface border border-border text-main font-semibold shadow hover:border-primary transition' do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M21.805 10.023h-9.765v3.977h5.617c-.242 1.242-1.484 3.648-5.617 3.648-3.383 0-6.148-2.805-6.148-6.25s2.765-6.25 6.148-6.25c1.93 0 3.227.82 3.969 1.523l2.711-2.648c-1.711-1.594-3.922-2.57-6.68-2.57-5.523 0-10 4.477-10 10s4.477 10 10 10c5.742 0 9.547-4.023 9.547-9.711 0-.652-.07-1.148-.156-1.539z"/></svg>
        <span>Sign up with Google</span>
      <% end %>
      <%= button_to auth_path(provider: 'github'), method: :post, class: 'cursor-pointer w-full flex items-center justify-center gap-2 px-6 py-2 rounded-lg bg-surface border border-border text-main font-semibold shadow hover:border-primary transition' do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.627 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.419-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.824 1.102.824 2.222v3.293c0 .319.192.694.801.576 4.769-1.589 8.201-6.086 8.201-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span>Sign up with GitHub</span>
      <% end %>
    </div>
    <div class="flex items-center my-6">
      <div class="flex-grow border-t border-border"></div>
      <span class="mx-4 text-text-muted text-sm">or sign up with email</span>
      <div class="flex-grow border-t border-border"></div>
    </div>
  </div>
  <% if @user.errors.any? %>
    <div class="bg-danger-surface text-danger-text rounded p-2 mb-2">
      <ul class="list-disc pl-5">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= form_with model: @user, url: registration_path, local: true, html: { class: 'space-y-6' } do |form| %>
    <div>
      <%= form.label :email_address, 'Email Address', class: 'block text-sm font-medium text-text-muted mb-1' %>
      <%= form.email_field :email_address, required: true, autofocus: true, class: 'w-full rounded-lg border border-border bg-background text-text-main px-4 py-2 focus:ring-2 focus:ring-primary focus:border-primary transition' %>
    </div>
    <div>
      <%= form.label :password, 'Password', class: 'block text-sm font-medium text-text-muted mb-1' %>
      <%= form.password_field :password, required: true, class: 'w-full rounded-lg border border-border bg-background text-text-main px-4 py-2 focus:ring-2 focus:ring-primary focus:border-primary transition' %>
    </div>
    <div>
      <%= form.label :password_confirmation, 'Confirm Password', class: 'block text-sm font-medium text-text-muted mb-1' %>
      <%= form.password_field :password_confirmation, required: true, class: 'w-full rounded-lg border border-border bg-background text-text-main px-4 py-2 focus:ring-2 focus:ring-primary focus:border-primary transition' %>
    </div>
    <div>
      <%= form.submit 'Sign Up', class: 'cursor-pointer w-full px-6 py-2 rounded-lg bg-primary text-white font-semibold shadow hover:bg-primary-hover transition' %>
    </div>
  <% end %>
  <div class="mt-6 text-center">
    <span class="text-text-muted">Already have an account?</span>
    <%= link_to 'Sign in', new_session_path, class: 'text-primary hover:underline font-semibold' %>
  </div>
</div>
